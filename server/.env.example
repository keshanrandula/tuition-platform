# Server configuration
PORT=5000
NODE_ENV=development

# Database configuration
MONGODB_URI=mongodb://127.0.0.1:27017/tuition-platform

# Authentication Secret
JWT_SECRET=your_jwt_secret_token_here

# Cloudinary credentials (for image/video storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Service SMTP credentials (for notifications/receipts)
EMAIL_USER=your_email_address@gmail.com
EMAIL_PASS=your_email_password_or_app_passcode

# AI / Chatbot configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash
